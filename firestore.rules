rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sadece kimliği doğrulanmış (veya anonim giriş yapmış) kullanıcıların erişimine izin ver
    // Özel auth fallback sistemi nedeniyle detaylı RBAC kuralı geçici olarak iptal edildi.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
