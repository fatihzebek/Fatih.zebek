        <div style={styles.controlsRow}>
          <input 
            type="text" 
            placeholder="Parça adı veya SAP numarası..." 
            style={styles.input}
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
          />
          <button style={{...styles.btn, ...styles.btnPrimary}}>Hızlı Sayım</button>
          <button style={styles.btn}>QR Tara</button>
          <button style={styles.btn}>İndir</button>
          <button style={styles.btn}>Yükle</button>
          <button style={{...styles.btn, backgroundColor: '#FFFFFF', color: '#000000'}}>+ Yeni Ekle</button>
        </div>
      </div>

      {/* Summary Cards */}
      <div style={styles.cardsGrid}>
        <div style={styles.card}>
          <div style={styles.cardTitle}>Toplam Kalem</div>
          <div style={styles.cardValue}>1,204</div>
        </div>
        <div style={{...styles.card, borderColor: 'rgba(239, 68, 68, 0.3)'}}>
          <div style={{...styles.cardTitle, color: '#EF4444'}}>Kritik Stok</div>
          <div style={{...styles.cardValue, color: '#EF4444'}}>12</div>
        </div>
        <div style={styles.card}>
          <div style={styles.cardTitle}>Son İşlemler</div>
          <div style={styles.cardValue}>45</div>
        </div>
        <div style={styles.card}>
          <div style={styles.cardTitle}>Son Hareket</div>
          <div style={styles.cardValue}>10 Dk Önce</div>
        </div>
        <div style={styles.card}>
          <div style={styles.cardTitle}>Depo Durumu</div>
          <div style={{...styles.cardValue, color: '#14F195'}}>Çevrimiçi</div>
        </div>
      </div>

      {/* AI Analytics Banner */}
      <div style={styles.banner}>
        <div style={styles.bannerText}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          Envanter Analitiği (AI): Önümüzdeki 30 gün içinde 12 kalemde stok tükenme riski tespit edildi.
        </div>
        <button style={{...styles.btn, ...styles.btnDanger}}>Sipariş Oluştur</button>
      </div>

      {/* Inventory Table */}
      <div style={styles.tableContainer}>
        <table style={styles.table}>
          <thead>
            <tr>
              <th style={{...styles.th, width: '40px'}}><input type="checkbox" /></th>
              <th style={styles.th}>Malzeme Tanımı</th>
              <th style={styles.th}>SAP No</th>
              <th style={styles.th}>Stok</th>
              <th style={styles.th}>Rezerve</th>
              <th style={styles.th}>Konum</th>
              <th style={{...styles.th, textAlign: 'right'}}>Aksiyonlar</th>
            </tr>
          </thead>
          <tbody>
            {MOCK_DATA.map((item, index) => (
              <tr key={index}>
                <td style={styles.td}><input type="checkbox" /></td>
                <td style={{...styles.td, fontWeight: '500'}}>{item.malzemeAdi}</td>
                <td style={{...styles.td, color: '#94A3B8'}}>{item.sapNo}</td>
                <td style={styles.td}>
                  <span style={item.stok <= item.kritikStok ? styles.stokBadgeCritical : styles.stokBadge}>
                    {item.stok} {item.birim}
                  </span>
                </td>
                <td style={{...styles.td, color: item.rezerve > 0 ? '#F59E0B' : '#94A3B8'}}>
                  {item.rezerve}
                </td>
                <td style={{...styles.td, color: '#94A3B8'}}>{item.konum}</td>
                <td style={{...styles.td, textAlign: 'right'}}>
                  <span style={styles.actionIcon}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  </span>
                  <span style={{...styles.actionIcon, color: '#EF4444'}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
