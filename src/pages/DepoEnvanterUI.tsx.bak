import React, { useState } from 'react';
import { IMalzeme } from '../types/depo';

const MOCK_DATA: IMalzeme[] = [
  { sapNo: '10005', malzemeAdi: 'sensor GRE6617 KTY81-110 E66', birim: 'Adet', stok: 3, rezerve: 0, konum: 'B.8', kritikStok: 5 },
  { sapNo: '1007517', malzemeAdi: 'Zinc dust primer Wieregen® DF35 0,25L', birim: 'Kutu', stok: 4, rezerve: 1, konum: 'Kimyasal', kritikStok: 2 },
  { sapNo: '101401', malzemeAdi: 'yaw drive Zollern®E82/E2 MK82004-0', birim: 'Adet', stok: 1, rezerve: 0, konum: 'Kapı yanı', kritikStok: 1 },
  { sapNo: '103190', malzemeAdi: 'slot wedge l=383mm 4002102-0', birim: 'Adet', stok: 24, rezerve: 5, konum: 'J.5', kritikStok: 10 }
];

export default function DepoEnvanterUI() {
  const [searchTerm, setSearchTerm] = useState('');

  // Styles defined internally for a self-contained component
  const styles = {
    container: {
      backgroundColor: '#0A0E17',
      minHeight: '100vh',
      color: '#E2E8F0',
      fontFamily: '"Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif',
      padding: '2rem',
      boxSizing: 'border-box' as const
    },
    headerRow: {
      display: 'flex',
      justifyContent: 'space-between',
      alignItems: 'center',
      marginBottom: '2rem'
    },
    title: {
      fontSize: '1.5rem',
      fontWeight: '600',
      color: '#FFFFFF',
      margin: 0
    },
    subtitle: {
      fontSize: '0.85rem',
      color: '#64748B',
      marginTop: '0.25rem'
    },
    controlsRow: {
      display: 'flex',
      gap: '0.75rem',
      alignItems: 'center'
    },
    input: {
      height: '42px',
      backgroundColor: '#111827',
      border: '1px solid #1E293B',
      borderRadius: '8px',
      color: '#E2E8F0',
      padding: '0 1rem',
      fontSize: '0.9rem',
      width: '280px',
      outline: 'none',
      transition: 'all 0.2s'
    },
    btn: {
      height: '42px',
      padding: '0 1rem',
      borderRadius: '8px',
      border: '1px solid #1E293B',
      backgroundColor: '#111827',
      color: '#E2E8F0',
      fontSize: '0.9rem',
      fontWeight: '500',
      cursor: 'pointer',
      display: 'flex',
      alignItems: 'center',
      gap: '0.5rem',
      transition: 'all 0.2s'
    },
    btnPrimary: {
      backgroundColor: '#14F195',
      color: '#0A0E17',
      border: 'none',
      fontWeight: '600'
    },
    btnDanger: {
      backgroundColor: '#EF4444',
      color: '#FFFFFF',
      border: 'none',
      fontWeight: '600'
    },
    cardsGrid: {
      display: 'grid',
      gridTemplateColumns: 'repeat(5, 1fr)',
      gap: '1rem',
      marginBottom: '2rem'
    },
    card: {
      backgroundColor: '#111827',
      border: '1px solid #1E293B',
      borderRadius: '12px',
      padding: '1.25rem',
      display: 'flex',
      flexDirection: 'column' as const,
      alignItems: 'center',
      justifyContent: 'center',
      gap: '0.5rem'
    },
    cardTitle: {
      fontSize: '0.8rem',
      color: '#94A3B8',
      textTransform: 'uppercase' as const,
      letterSpacing: '0.05em'
    },
    cardValue: {
      fontSize: '1.75rem',
      fontWeight: '700',
      color: '#FFFFFF'
    },
    banner: {
      backgroundColor: 'rgba(239, 68, 68, 0.1)',
      border: '1px solid rgba(239, 68, 68, 0.2)',
      borderRadius: '12px',
      padding: '1rem 1.5rem',
      display: 'flex',
      justifyContent: 'space-between',
      alignItems: 'center',
      marginBottom: '2rem'
    },
    bannerText: {
      color: '#FCA5A5',
      fontSize: '0.9rem',
      display: 'flex',
      alignItems: 'center',
      gap: '0.5rem'
    },
    tableContainer: {
      backgroundColor: '#111827',
      border: '1px solid #1E293B',
      borderRadius: '12px',
      overflow: 'hidden'
    },
    table: {
      width: '100%',
      borderCollapse: 'collapse' as const,
      fontSize: '0.9rem'
    },
    th: {
      padding: '1rem',
      textAlign: 'left' as const,
      color: '#64748B',
      fontWeight: '600',
      borderBottom: '1px solid #1E293B',
      fontSize: '0.85rem',
      textTransform: 'uppercase' as const
    },
    td: {
      padding: '1rem',
      color: '#E2E8F0',
      borderBottom: '1px solid rgba(30, 41, 59, 0.5)'
    },
    stokBadge: {
      backgroundColor: 'rgba(20, 241, 149, 0.1)',
      color: '#14F195',
      padding: '0.25rem 0.5rem',
      borderRadius: '4px',
      fontSize: '0.8rem',
      fontWeight: '600'
    },
    stokBadgeCritical: {
      backgroundColor: 'rgba(239, 68, 68, 0.1)',
